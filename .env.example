# Fantasy Movie League - Environment Variables
# Copy this file to .env and fill in your API keys

# OMDb API (IMDB ratings + RT scores) — get a free key at https://www.omdbapi.com/apikey.aspx
OMDB_API_KEY=

# TMDB API (movie posters) — get a free key at https://www.themoviedb.org/settings/api
TMDB_API_KEY=

# Server port (default 3001)
PORT=3001

# Admin password — required to create seasons, draft periods, manage drafts
ADMIN_PASSWORD=
